# ============================================================
# SIAD MAG Distribution — ETL Environment Variables
# ============================================================
# Adapter les noms de serveur/base selon votre instance SQL Server

# Data Warehouse cible
DW_CONN=mssql+pyodbc://localhost/DW_SIAD?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# Source Sage Gestion Commerciale
MAG_CONN=mssql+pyodbc://localhost/MAG_2020?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# Source Sage Trésorerie
GRT_CONN=mssql+pyodbc://localhost/GRT_MAG?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# Logging
ETL_LOG_LEVEL=INFO
ETL_LOG_FILE=etl_run.log

# Performance
ETL_CHUNK_SIZE=10000

# Plage DIM_DATE
DIM_DATE_START=2015-01-01
DIM_DATE_END=2030-12-31
