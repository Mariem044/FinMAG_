# Data Warehouse cible
DW_CONN=mssql+pyodbc://@.\SQLEXPRESS/DW_SIAD?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# Source Sage Gestion Commerciale
MAG_CONN=mssql+pyodbc://@.\SQLEXPRESS/MAG_2020?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# Source Sage Trésorerie
GRT_CONN=mssql+pyodbc://@.\SQLEXPRESS/GRT_MAG?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# Logging
ETL_LOG_LEVEL=INFO
ETL_LOG_FILE=etl_run.log

# Performance
ETL_CHUNK_SIZE=10000

# Plage DIM_DATE
DIM_DATE_START=2015-01-01
DIM_DATE_END=2030-12-31

# ── API CORS ────────────────────────────────────────────────
API_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_DEFAULT_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

ETL_AUDIT_TABLE=ETL_AUDIT

# ── Hachage des clés de substitution ────────────────────────────────────────
# MINIMUM 8 octets pour éviter les collisions sur grands datasets (>50k lignes)
ETL_HASH_BYTES=8

# ── Paramètres ETL ────────────────────────────────────────────────────────────
ETL_ERROR_MSG_MAX_LEN=500
ETL_STALE_RUNNING_HOURS=6
ETL_QUERY_TIMEOUT=300

# ── Seuil tension stock ───────────────────────────────────────────────────────
SEUIL_TENSION_STOCK=0.5
